# Google Maps JavaScript API key (Maps JavaScript API must be enabled in Google Cloud).
# Free tier: ~$200/month credit. Set billing on the GCP project.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional — Google Sign-In (account page)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Optional — Apple Sign-In
APPLE_CLIENT_ID=your.apple.service.id

# Dev only — allow OAuth without token verification (email prompt)
OAUTH_DEV_MODE=1

PORT=3010

# SQLite database path (absolute or relative to project root). Default: data/paint_market.sqlite
# DATABASE_PATH=data/paint_market.sqlite

# Local backup folder (Developer Actions + npm run backup-db). Default: backups/
# Uses legacy db-backups/ automatically if it already contains backups and backups/ is empty.
# BACKUP_DIR=backups
# Optional — duplicate each backup here (e.g. second drive). Used by Developer Actions + npm run backup-db.
# BACKUP_MIRROR_DIR=D:/paint-market/backups
# BACKUP_RETENTION_DAYS=14

# Seed command — create dev admin (never in production)
# SEED_DEV_ADMIN=1
